# Local Ollama execution does not require an API key.
PAPER_ORCHESTRATION_CONFIG=model-providers.toml
PAPER_ORCHESTRATION_PROFILE=ollama
# PAPER_ORCHESTRATION_MODEL=ollama:gpt-oss:20b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# OpenAI remains available by selecting a profile and setting its key.
# PAPER_ORCHESTRATION_PROFILE=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Backwards-compatible model settings
# OPENAI_MODEL=openai:gpt-4o-mini
# BEAVERS_CHOICE_AGENT_MODEL=openai:gpt-4o-mini

BEAVERS_CHOICE_DB_PATH=./outputs/munder_difflin.db

